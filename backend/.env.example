# Firebase Admin SDK Service Account
# Download from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=sarina-ai-2b2c1
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@sarina-ai-2b2c1.iam.gserviceaccount.com

# Gemini API Key
# Get from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
PORT=8080
NODE_ENV=production

# Credit Deduction Settings
HEARTBEAT_INTERVAL_SECONDS=5
MINIMUM_CALL_BALANCE_SECONDS=10

# Gemini Voice Configuration
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_VOICE=Aoede
