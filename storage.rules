rules_version = '2';

// Firebase Storage Security Rules for Sarina AI App
// Production-ready configuration

service firebase.storage {
  match /b/{bucket}/o {

    // Videos folder - Public read, no write
    match /videos/{videoFile} {
      // Allow anyone to read/download videos
      allow read: if true;

      // Deny all write operations (upload, update, delete)
      // Videos should only be uploaded via Firebase Console or authenticated admin
      allow write: if false;
    }

    // User uploads folder (if you add user profile pictures later)
    match /user-uploads/{userId}/{allPaths=**} {
      // Users can read their own uploads
      allow read: if request.auth != null && request.auth.uid == userId;

      // Users can write to their own folder
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024; // Max 5MB
    }

    // Admin folder (for future admin features)
    match /admin/{allPaths=**} {
      // Only authenticated admin users can access
      allow read, write: if request.auth != null
                         && request.auth.token.admin == true;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
